# ─── App ──────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Connection-pool tunables: keep the pool tight on Render's shared cores. The
# default Prisma pool is `num_physical_cpus * 2 + 1` which on a 0.5 vCPU
# instance is 3 — too few under load. Setting it explicitly also stops Prisma
# from probing CPU count at boot.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&connection_limit=20&pool_timeout=10"

# Direct (non-pooled) connection — used by `prisma migrate` only.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&connect_timeout=30"

# Local-dev only: tunnel Postgres through Neon's WS-on-443 if your network
# blocks outbound :5432. Render and other clouds leave this unset.
USE_NEON_HTTP=

# ─── Rate limiting ────────────────────────────────────────────────────────────
# DEV ONLY: when set to `1` (and NODE_ENV != production), every rate limiter
# in this app is bypassed. Lets you load-test from a single IP without hitting
# the global 500-req-per-15-min cap. Fails closed in production.
DISABLE_RATE_LIMIT=

# Note: the rate limiter persists its counters in Postgres via the same
# `DATABASE_URL` (no Redis required). On boot it migrates a `rate_limit`
# schema. If your DATABASE_URL user lacks DDL rights, run those migrations
# manually once or grant CREATE on the schema.

# ─── DB-slowdown simulator (dev only) ─────────────────────────────────────────
# Used by the loadtest validation suite to exercise the circuit breaker, the
# stale-while-revalidate fallback path, and the frontend timeout/retry policy
# WITHOUT having to actually break Neon for everyone. All three knobs are
# hard-locked to NODE_ENV != production — they are silently ignored in prod.
#
#   DB_INJECT_DELAY_MS    fixed delay added to every Prisma op (e.g. 200)
#   DB_INJECT_JITTER_MS   ± uniform jitter on top of the fixed delay (e.g. 50)
#   DB_INJECT_FAIL_PCT    percent of ops that synthetically throw P1001
DB_INJECT_DELAY_MS=
DB_INJECT_JITTER_MS=
DB_INJECT_FAIL_PCT=

# ─── Security ─────────────────────────────────────────────────────────────────
# Local dev only — disables TLS verification for self-signed Neon certs etc.
# NEVER set to 1 in production.
ALLOW_INSECURE_TLS=

# ─── Auth (Firebase Admin) ────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Multi-line PEM. Use literal `\n` in `.env` (dotenv un-escapes them at load).
FIREBASE_PRIVATE_KEY=

# ─── Storage (Cloudinary) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Push notifications (Web Push / VAPID) ────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ─── Email (transactional) ────────────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=

# ─── Google Sheets sync (optional) ────────────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
