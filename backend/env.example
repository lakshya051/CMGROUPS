# Copy to .env locally. On Render, set these in the service Environment tab.

# Pooled URL (Neon "Transaction" / pooler) — fine for the running app.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct URL (Neon "Connection string" without -pooler, port 5432) — required for `prisma migrate deploy`.
# If you omit this, set DIRECT_URL to the same value as DATABASE_URL (e.g. local Postgres).
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
