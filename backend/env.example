# Copy to .env locally. On Render, set these in the service Environment tab.

# Pooled URL (Neon "Transaction" / pooler) — fine for the running app.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct URL (Neon host WITHOUT "-pooler", port 5432) — used by `prisma migrate deploy` (see schema directUrl).
# Add connect_timeout for cold starts: ...?sslmode=require&connect_timeout=30
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# Render build retries (optional)
# PRISMA_MIGRATE_MAX_ATTEMPTS=5
# PRISMA_MIGRATE_RETRY_DELAY_MS=20000
# Last resort if P1002 persists (single migration runner only — e.g. one Render web service):
# PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1
