// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  clerkId        String?  @unique
  email          String   @unique
  name           String?
  phone          String?
  referralCode   String?  @unique
  walletBalance  Float    @default(0)
  tier           String   @default("Bronze")
  tierPoints     Float    @default(0)
  referredById   Int?
  referredBy     User?    @relation("UserReferrals", fields: [referredById], references: [id])
  role           String   @default("customer")
  createdAt      DateTime @default(now())
  
  orders    Order[]
  reviews   Review[]
  bookings  ServiceBooking[]
  referrals User[]     @relation("UserReferrals")
  referralsMade     Referral[] @relation("Referrer")
  referralsReceived Referral[] @relation("Referee")
  walletTransactions WalletTransaction[]
  productAlerts      ProductAlert[]
  notifications      Notification[]
  wishlists          Wishlist[]
  cartItems          CartItem[]
  
  // Education Module
  courseApplications CourseApplication[]
  enrollments        Enrollment[]
  attendances        Attendance[]
}

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  instructor  String
  category    String   @default("Computer")
  thumbnail   String   @default("")
  hasCertificate Boolean @default(true)
  isPublished Boolean  @default(true)
  referrerPoints    Float?
  refereePoints     Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications CourseApplication[]
  durations    CourseDuration[]
  enrollments  Enrollment[]  // kept for backward compat
  materials    CourseMaterial[]
  attendances  Attendance[]
}

model CourseDuration {
  id               Int      @id @default(autoincrement())
  courseId         Int
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  label            String   // "3 Months", "6 Months"
  totalFee         Float
  fullPayDiscount  Float    @default(0)  // discount % for full upfront payment
  installments     Int      @default(3)  // number of monthly installments
  batches          CourseBatch[]
  applications     CourseApplication[]
}

model CourseBatch {
  id           Int            @id @default(autoincrement())
  durationId   Int
  duration     CourseDuration @relation(fields: [durationId], references: [id], onDelete: Cascade)
  name         String         // "Morning", "Afternoon", "Evening"
  timing       String         // "10:00 AM – 12:00 PM"
  seatLimit    Int            @default(20)
  applications CourseApplication[]
}

model CourseApplication {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  courseId     Int
  course       Course   @relation(fields: [courseId], references: [id])
  durationId   Int?
  duration     CourseDuration? @relation(fields: [durationId], references: [id])
  batchId      Int?
  batch        CourseBatch?    @relation(fields: [batchId], references: [id])
  name         String
  email        String
  phone        String
  message      String?
  paymentMode  String   @default("Installment") // "Full" | "Installment"
  referralCode String?
  status       String   @default("Pending")     // "Pending" | "Approved" | "Rejected" | "Enrolled" | "Completed"
  enrolledAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  feePayments  FeePayment[]

  @@index([userId])
  @@index([status])
  @@index([courseId])
}

model FeePayment {
  id            Int              @id @default(autoincrement())
  applicationId Int
  application   CourseApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  amount        Float
  note          String?
  paidAt        DateTime         @default(now())
  markedBy      String           // admin email
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id])
  status        String   @default("Active") // "Active", "Completed", "Dropped"
  progress      Int      @default(0)
  paymentStatus String   @default("Pending") // "Pending", "Partial", "Paid"
  feePaid       Float    @default(0)
  createdAt     DateTime @default(now())
  
  attendances   Attendance[]

  @@unique([userId, courseId])
}

model CourseMaterial {
  id          Int      @id @default(autoincrement())
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])
  title       String
  description String?
  fileUrl     String
  fileType    String   // "PDF", "Video", "Link", "Document"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  courseId     Int
  course       Course     @relation(fields: [courseId], references: [id])
  enrollmentId Int
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  date         DateTime
  status       String     @default("Present") // "Present", "Absent", "Late"
  notes        String?
  createdAt    DateTime   @default(now())

  @@unique([enrollmentId, date])
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  amount      Float
  type        String   // "CREDIT" | "DEBIT"
  description String
  orderId     Int?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  price       Float
  stock       Int
  category    String
  brand       String?
  image       String
  description String?
  specs       Json?
  rating      Float    @default(0)
  numReviews  Int      @default(0)
  condition   String   @default("New")
  isSecondHand Boolean @default(false)
  isReturnable Boolean @default(true)
  returnWindowDays Int @default(3)
  referrerPoints    Float?
  refereePoints     Float?
  
  orderItems  OrderItem[]
  reviews     Review[]
  alerts      ProductAlert[]
  wishlists   Wishlist[]
  variants    ProductVariant[]
  cartItems   CartItem[]

  @@index([category])
  @@index([isSecondHand])
  @@index([price])
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, variantId])
  @@index([userId])
}


model Order {
  id              Int         @id @default(autoincrement())
  userId          Int?
  user            User?       @relation(fields: [userId], references: [id])
  total           Float
  walletUsed      Float       @default(0)
  status          String      @default("Processing")
  paymentMethod   String      @default("pay_at_store")
  paymentOtp      String?
  isPaid          Boolean     @default(false)
  shippingAddress Json?
  guestInfo       Json?
  referralCodeUsed String?
  couponCode      String?
  discountAmount  Float       @default(0)
  createdAt       DateTime    @default(now())
  
  // Cancellation & Return Fields
  cancelReason    String?
  returnReason    String?
  returnStatus    String      @default("None") // "None", "Requested", "Approved", "Rejected", "Completed"
  refundStatus    String      @default("None") // "None", "Pending", "Processed"
  refundAmount    Float?
  deliveredAt     DateTime?
  referralEligibleAt DateTime?

  items           OrderItem[]
  referrals       Referral[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  rating    Int
  comment   String?
  images    String[]   @default([])
  isVerified Boolean   @default(false)
  helpfulVotes Int     @default(0)
  voters    Int[]      @default([]) // Store user IDs who voted
  createdAt DateTime @default(now())
}

model ServiceBooking {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  serviceType    String
  description    String?
  deviceType     String?
  deviceBrand    String?
  date           DateTime
  timeSlot       String?
  status         String   @default("Pending")
  referralCodeUsed String?
  // Customer details
  customerName   String?
  customerPhone  String?
  address        String?
  city           String?
  pincode        String?
  landmark       String?
  // Admin fields
  estimatedPrice Float?
  finalPrice     Float?
  adminNotes     String?
  assignedTo     String?
  // OTP for pickup verification
  pickupOtp      String?
  // Timestamps
  confirmedAt    DateTime?
  pickedUpAt     DateTime?
  completedAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime @default(now())
}

model Coupon {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  discountType   String    // "percent" or "fixed"
  value          Float
  active         Boolean   @default(true)
  expiresAt      DateTime?
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int       @default(0)
}

model Referral {
  id           Int       @id @default(autoincrement())
  referrerId   Int
  referrer     User      @relation("Referrer", fields: [referrerId], references: [id])
  refereeId    Int
  referee      User      @relation("Referee", fields: [refereeId], references: [id])
  status       String    @default("pending")  // "pending" | "completed" | "rewarded"
  rewardAmount Float     @default(200)       // This is the referrer's reward
  refereeReward Float?                        // This is the referee's reward
  orderId      Int?
  order        Order?    @relation(fields: [orderId], references: [id])
  source       String    @default("shopping") // "shopping" | "course"
  courseName   String?   // name of the course (for display in portal)
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  image       String?
  description String?
  createdAt   DateTime @default(now())
}

model ServiceType {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  icon        String?     // Icon name e.g. "Wrench", "Monitor", "Cpu"
  price       String?     // Starting price e.g. "₹499"
  features    Json?       // Array of feature strings
  active      Boolean  @default(true)
  referrerPoints    Float?
  refereePoints     Float?
  createdAt   DateTime @default(now())
}

model ProductVariant {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String   // e.g. "64GB", "Red", "512GB SSD"
  price       Float    // variant specific price
  stock       Int      @default(0)
  sku         String?  // optional stock keeping unit code
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[] // so order items can reference a variant
  cartItems   CartItem[]
}

model ProductAlert {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  type      String   // "STOCK" | "PRICE_DROP"
  priceThreshold Float? // For price drop alerts, notify if price drops below this
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, productId, type])
  @@index([userId])
  @@index([productId, type, isActive])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // "ALERT" | "ORDER" | "SYSTEM"
  isRead    Boolean  @default(false)
  link      String?  // Optional link to redirect user
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model ReferralSettings {
  id                        Int      @id @default(autoincrement())
  pointsPerProductPurchase  Float    @default(200)
  pointsPerServiceBooking   Float    @default(100)
  pointsPerCourseEnrollment Float    @default(300)
  pointToRupeeRate          Float    @default(100) // 100 points = ₹10
  pointExpiryDays           Int?     // null = no expiry
  tierSystemEnabled         Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  
  @@unique([id]) // Single settings record
}

model TierConfig {
  id        Int    @id @default(autoincrement())
  tierName  String @unique
  minPoints Float
  color     String @default("#CD7F32")
}

model TallyEnquiry {
  id           Int      @id @default(autoincrement())
  name         String
  businessName String
  phone        String
  city         String
  licenseType  String
  message      String?
  status       String   @default("new") // "new" | "contacted" | "converted"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ServiceSettings {
  id                 Int      @id @default(autoincrement())
  timeSlots          String[]
  maxBookingsPerSlot Int      @default(2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

