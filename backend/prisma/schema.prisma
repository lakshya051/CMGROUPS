// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  firebaseUid   String?  @unique
  email         String   @unique
  name          String?
  phone         String?
  referralCode  String?  @unique
  walletBalance Float    @default(0)
  tier          String   @default("Bronze")
  tierPoints    Float    @default(0)
  referredById  Int?
  referredBy    User?    @relation("UserReferrals", fields: [referredById], references: [id])
  role          String   @default("customer")
  createdAt     DateTime @default(now())

  orders              Order[]
  reviews             Review[]
  bookings            ServiceBooking[]
  referrals           User[]               @relation("UserReferrals")
  referralsMade       Referral[]           @relation("Referrer")
  referralsReceived   Referral[]           @relation("Referee")
  walletTransactions  WalletTransaction[]
  productAlerts       ProductAlert[]
  notifications       Notification[]
  deviceRegistrations DeviceRegistration[]
  pushSubscriptions   PushSubscription[]
  wishlists           Wishlist[]
  cartItems           CartItem[]
  addresses           Address[]

  // Education Module
  courseApplications CourseApplication[]
  enrollments        Enrollment[]
  attendances        Attendance[]
  auditLogs          AuditLog[]
  bundleReviews      BundleReview[] @relation("BundleReviews")

  @@index([firebaseUid])
  @@index([role])
  @@index([createdAt])
}

model Course {
  id             Int      @id @default(autoincrement())
  title          String
  description    String
  instructor     String
  category       String   @default("Computer")
  thumbnail      String   @default("")
  hasCertificate Boolean  @default(true)
  isPublished    Boolean  @default(true)
  referrerPoints Float?
  refereePoints  Float?
  sellerName     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  applications CourseApplication[]
  durations    CourseDuration[]
  enrollments  Enrollment[] // kept for backward compat
  materials    CourseMaterial[]
  attendances  Attendance[]
  bundleItems  BundleItem[]
}

model CourseDuration {
  id              Int                 @id @default(autoincrement())
  courseId        Int
  course          Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  label           String // "3 Months", "6 Months"
  totalFee        Float
  fullPayDiscount Float               @default(0) // discount % for full upfront payment
  installments    Int                 @default(3) // number of monthly installments
  batches         CourseBatch[]
  applications    CourseApplication[]
}

model CourseBatch {
  id           Int                 @id @default(autoincrement())
  durationId   Int
  duration     CourseDuration      @relation(fields: [durationId], references: [id], onDelete: Cascade)
  name         String // "Morning", "Afternoon", "Evening"
  timing       String // "10:00 AM – 12:00 PM"
  seatLimit    Int                 @default(20)
  applications CourseApplication[]
}

model CourseApplication {
  id           Int             @id @default(autoincrement())
  userId       Int
  user         User            @relation(fields: [userId], references: [id])
  courseId     Int
  course       Course          @relation(fields: [courseId], references: [id])
  durationId   Int?
  duration     CourseDuration? @relation(fields: [durationId], references: [id])
  batchId      Int?
  batch        CourseBatch?    @relation(fields: [batchId], references: [id])
  name         String
  email        String
  phone        String
  message      String?
  paymentMode  String          @default("Installment") // "Full" | "Installment"
  referralCode String?
  status       String          @default("Pending") // "Pending" | "Approved" | "Rejected" | "Enrolled" | "Completed"
  enrolledAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())

  feePayments FeePayment[]

  @@index([userId])
  @@index([status])
  @@index([courseId])
  @@index([durationId])
  @@index([batchId])
}

model FeePayment {
  id            Int               @id @default(autoincrement())
  applicationId Int
  application   CourseApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  amount        Float
  note          String?
  paidAt        DateTime          @default(now())
  markedBy      String // admin email
}

model Enrollment {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  courseId      Int
  course        Course   @relation(fields: [courseId], references: [id])
  status        String   @default("Active") // "Active", "Completed", "Dropped"
  progress      Int      @default(0)
  paymentStatus String   @default("Pending") // "Pending", "Partial", "Paid"
  feePaid       Float    @default(0)
  createdAt     DateTime @default(now())

  attendances Attendance[]

  @@unique([userId, courseId])
}

model CourseMaterial {
  id          Int      @id @default(autoincrement())
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])
  title       String
  description String?
  fileUrl     String
  fileType    String // "PDF", "Video", "Link", "Document"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  courseId     Int
  course       Course     @relation(fields: [courseId], references: [id])
  enrollmentId Int
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  date         DateTime
  status       String     @default("Present") // "Present", "Absent", "Late"
  notes        String?
  createdAt    DateTime   @default(now())

  @@unique([enrollmentId, date])
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  amount      Float
  type        String // "CREDIT" | "DEBIT"
  description String
  orderId     Int?
  order       Order?   @relation(fields: [orderId], references: [id])
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([orderId])
}

model Product {
  id               Int      @id @default(autoincrement())
  title            String
  price            Float
  originalPrice    Float?
  stock            Int
  category         String
  brand            String?
  sellerName       String?
  images           String[] @default([])
  description      String?
  specs            Json?
  rating           Float    @default(0)
  numReviews       Int      @default(0)
  condition        String   @default("New")
  isSecondHand     Boolean  @default(false)
  isRefurbished    Boolean  @default(false)
  isReturnable     Boolean  @default(true)
  returnWindowDays Int      @default(3)
  referrerPoints   Float?
  refereePoints    Float?
  isActive         Boolean  @default(true)
  isDeal           Boolean  @default(false)

  hasVariants Boolean  @default(false)

  orderItems     OrderItem[]
  reviews        Review[]
  alerts         ProductAlert[]
  wishlists      Wishlist[]
  variants       ProductVariant[]
  variantOptions VariantOption[]
  cartItems      CartItem[]
  bundleItems    BundleItem[]
  quantityTiers  QuantityTier[]

  @@index([category])
  @@index([isSecondHand])
  @@index([isRefurbished])
  @@index([price])
  @@index([rating])
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

model CartItem {
  id               Int             @id @default(autoincrement())
  userId           Int
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId        Int
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId        Int?
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity         Int             @default(1)
  bundleId         String?
  bundleInstanceId String          @default("")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([userId, productId, variantId, bundleInstanceId])
  @@index([userId])
}

model Order {
  id               Int      @id @default(autoincrement())
  userId           Int?
  user             User?    @relation(fields: [userId], references: [id])
  total            Float
  walletUsed       Float    @default(0)
  status           String   @default("Processing")
  paymentMethod    String   @default("pay_at_store")
  paymentOtp       String?
  isPaid           Boolean  @default(false)
  shippingAddress  Json?
  guestInfo        Json?
  referralCodeUsed String?
  couponCode       String?
  discountAmount   Float    @default(0)
  giftWrap         Boolean  @default(false)
  giftMessage      String?
  createdAt        DateTime @default(now())

  // Cancellation & Return Fields
  cancelReason       String?
  returnReason       String?
  returnStatus       String    @default("None")
  refundStatus       String    @default("None")
  refundAmount       Float?
  deliveredAt        DateTime?
  referralEligibleAt DateTime?

  // Smart Delivery location fields
  latitude      Float?
  longitude     Float?
  googleMapLink String?

  items              OrderItem[]
  referrals          Referral[]
  serviceBookings    ServiceBooking[]
  walletTransactions WalletTransaction[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([returnStatus])
  @@index([isPaid])
  @@index([isPaid, createdAt])
}

model OrderItem {
  id               Int             @id @default(autoincrement())
  orderId          Int
  order            Order           @relation(fields: [orderId], references: [id])
  productId        Int
  product          Product         @relation(fields: [productId], references: [id])
  quantity         Int
  price            Float
  variantId        Int?
  variant          ProductVariant? @relation(fields: [variantId], references: [id])
  bundleId         Int?
  bundle           Bundle?         @relation(fields: [bundleId], references: [id])
  bundleInstanceId String?
  bundleTemplateId Int?
  bundleTemplate   BundleTemplate? @relation(fields: [bundleTemplateId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@index([bundleId])
  @@index([bundleTemplateId])
}

model Review {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  productId    Int
  product      Product  @relation(fields: [productId], references: [id])
  rating       Int
  comment      String?
  images       String[] @default([])
  isVerified   Boolean  @default(false)
  helpfulVotes Int      @default(0)
  voters       Int[]    @default([]) // Store user IDs who voted
  createdAt    DateTime @default(now())

  @@index([productId, createdAt])
  @@index([userId, productId])
}

model ServiceBooking {
  id               Int       @id @default(autoincrement())
  userId           Int
  user             User      @relation(fields: [userId], references: [id])
  orderId          Int?
  order            Order?    @relation(fields: [orderId], references: [id])
  serviceType      String
  description      String?
  deviceType       String?
  deviceBrand      String?
  date             DateTime
  timeSlot         String?
  status           String    @default("Pending")
  referralCodeUsed String?
  customFields     Json? // Dynamic field values { fieldName: value }
  // Customer details
  customerName     String?
  customerPhone    String?
  address          String?
  city             String?
  pincode          String?
  landmark         String?
  // Location (GPS)
  latitude         Float?
  longitude        Float?
  googleMapLink    String?
  // Admin fields
  estimatedPrice   Float?
  finalPrice       Float?
  adminNotes       String?
  assignedTo       String?
  // OTP for pickup verification
  pickupOtp        String?
  // OTP for delivery verification
  deliveryOtp            String?
  deliveryOtpVerified    Boolean   @default(false)
  deliveryOtpGeneratedAt DateTime?
  // Timestamps
  confirmedAt      DateTime?
  pickedUpAt       DateTime?
  completedAt      DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime  @default(now())

  // --- Service Hub Upgrade Fields ---
  // OTP verification
  otpVerified             Boolean     @default(false)
  otpGeneratedAt          DateTime?
  // Technician assignment
  technicianId            Int?
  technician              Technician? @relation(fields: [technicianId], references: [id])
  // Scheduling & invoice
  estimatedCompletionDate DateTime?
  invoiceUrl              String?
  // Cancellation
  cancelledAt             DateTime?
  cancellationReason      String?
  // Customer feedback
  customerRating          Int?
  customerReview          String?

  // Relations
  invoice ServiceInvoice?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([date])
  @@index([date, timeSlot, status])
  @@index([technicianId])
  @@index([orderId])
}

model Technician {
  id        Int              @id @default(autoincrement())
  name      String
  phone     String           @unique
  email     String?          @unique
  skills    String[] // e.g. ["Laptop Repair", "CCTV"]
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  bookings  ServiceBooking[]

  @@index([isActive])
}

model ServiceInvoice {
  id             Int            @id @default(autoincrement())
  bookingId      Int            @unique
  invoiceNumber  String         @unique
  serviceType    String
  technicianName String
  laborCost      Float
  partsCost      Float          @default(0)
  partsNotes     String?
  gst            Float
  totalAmount    Float
  pdfUrl         String?
  createdAt      DateTime       @default(now())
  booking        ServiceBooking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Coupon {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  discountType   String
  value          Float
  active         Boolean   @default(true)
  expiresAt      DateTime?
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int       @default(0)
  applicableTo   String    @default("all")
}

model Referral {
  id            Int       @id @default(autoincrement())
  referrerId    Int
  referrer      User      @relation("Referrer", fields: [referrerId], references: [id])
  refereeId     Int
  referee       User      @relation("Referee", fields: [refereeId], references: [id])
  status        String    @default("pending") // "pending" | "completed" | "rewarded"
  rewardAmount  Float     @default(200) // This is the referrer's reward
  refereeReward Float? // This is the referee's reward
  orderId       Int?
  order         Order?    @relation(fields: [orderId], references: [id])
  source        String    @default("shopping") // "shopping" | "course"
  courseName    String? // name of the course (for display in portal)
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@unique([orderId]) // Prevents duplicate referral payouts for the same order
  @@index([referrerId])
  @@index([refereeId])
  @@index([status])
  @@index([source])
  @@index([referrerId, status])
  @@index([referrerId, source])
  @@index([refereeId, referrerId, source])
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  image       String?
  description String?
  createdAt   DateTime @default(now())

  @@index([name])
}

model ServiceType {
  id             Int      @id @default(autoincrement())
  title          String   @unique
  description    String?
  icon           String? // Icon name e.g. "Wrench", "Monitor", "Cpu"
  price          String? // Starting price e.g. "₹499"
  features       Json? // Array of feature strings
  formFields     Json? // Array of { name, label, type, required, options }
  active         Boolean  @default(true)
  referrerPoints Float?
  refereePoints  Float?
  sellerName     String?
  createdAt      DateTime @default(now())
  bundleItems    BundleItem[]

  @@index([active])
}

model VariantOption {
  id        Int                  @id @default(autoincrement())
  productId Int
  name      String
  position  Int                  @default(0)
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    VariantOptionValue[]

  @@index([productId])
}

model VariantOptionValue {
  id       Int           @id @default(autoincrement())
  optionId Int
  value    String
  position Int           @default(0)
  option   VariantOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId])
}

model ProductVariant {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String?
  combination   Json?
  price         Float
  originalPrice Float?
  stock         Int      @default(0)
  sku           String?  @unique
  isActive      Boolean  @default(true)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems  OrderItem[]
  cartItems   CartItem[]
  bundleItems BundleItem[]

  @@index([productId])
  @@index([productId, price])
  @@index([sku])
}

model ProductAlert {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  productId      Int
  product        Product  @relation(fields: [productId], references: [id])
  type           String // "STOCK" | "PRICE_DROP"
  priceThreshold Float? // For price drop alerts, notify if price drops below this
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@unique([userId, productId, type])
  @@index([userId])
  @@index([productId, type, isActive])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String // "ALERT" | "ORDER" | "SYSTEM"
  isRead    Boolean  @default(false)
  link      String? // Optional link to redirect user
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model DeviceRegistration {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  platform   String
  token      String   @unique
  isActive   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, platform, isActive])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model ReferralSettings {
  id                        Int      @id @default(autoincrement())
  pointsPerProductPurchase  Float    @default(200)
  pointsPerServiceBooking   Float    @default(100)
  pointsPerCourseEnrollment Float    @default(300)
  pointToRupeeRate          Float    @default(100) // 100 points = ₹10
  pointExpiryDays           Int? // null = no expiry
  tierSystemEnabled         Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model TierConfig {
  id        Int    @id @default(autoincrement())
  tierName  String @unique
  minPoints Float
  color     String @default("#CD7F32")
}

model TallyEnquiry {
  id           Int      @id @default(autoincrement())
  name         String
  businessName String
  phone        String
  city         String
  licenseType  String
  message      String?
  sellerName   String?
  status       String   @default("new") // "new" | "contacted" | "converted"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, createdAt])
}

model CCTVEnquiry {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String
  city          String
  propertyType  String
  camerasNeeded String
  message       String?
  sellerName    String?
  status        String   @default("new") // "new" | "contacted" | "converted"
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
}

model ServiceSettings {
  id                 Int      @id @default(autoincrement())
  timeSlots          String[]
  maxBookingsPerSlot Int      @default(2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Banner {
  id           Int      @id @default(autoincrement())
  title        String
  subtitle     String?
  ctaLabel     String   @default("Shop Now")
  ctaLink      String   @default("/products")
  image        String?
  gradient     String?
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@index([active, displayOrder])
}

model Address {
  id            String   @id @default(uuid())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String?
  address       String
  city          String
  pincode       String
  phone         String
  latitude      Float?
  longitude     Float?
  googleMapLink String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

// ─── Bundle System ─────────────────────────────────────────────────────────────

model Bundle {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String?      @unique
  description String?
  image       String?
  bundlePrice Float
  isActive    Boolean      @default(true)
  isGiftable  Boolean      @default(false)
  displayOn   String[]     @default(["home"])
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  items       BundleItem[]
  orderItems  OrderItem[]
  reviews     BundleReview[]

  @@index([isActive])
  @@index([isActive, startDate, endDate])
}

model BundleItem {
  id            Int             @id @default(autoincrement())
  bundleId      Int
  bundle        Bundle          @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId     Int?
  product       Product?        @relation(fields: [productId], references: [id])
  variantId     Int?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  quantity      Int             @default(1)
  serviceTypeId Int?
  serviceType   ServiceType?    @relation(fields: [serviceTypeId], references: [id])
  courseId      Int?
  course        Course?         @relation(fields: [courseId], references: [id])
  itemType      String          @default("product")
  position      Int             @default(0)

  @@index([bundleId])
}

model BundleReview {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation("BundleReviews", fields: [userId], references: [id])
  bundleId     Int
  bundle       Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  rating       Int
  comment      String?
  isVerified   Boolean  @default(false)
  helpfulVotes Int      @default(0)
  voters       Int[]    @default([])
  createdAt    DateTime @default(now())

  @@index([bundleId, createdAt])
  @@index([userId, bundleId])
}

model BundleTemplate {
  id            Int                  @id @default(autoincrement())
  name          String
  description   String?
  image         String?
  discount      Float                @default(10)
  discountType  String               @default("flat")
  discountTiers Json?
  templateType  String               @default("slot")
  mixMatchQty   Int?
  mixMatchPrice Float?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  slots         BundleTemplateSlot[]
  orderItems    OrderItem[]

  @@index([isActive])
}

model BundleTemplateSlot {
  id         Int            @id @default(autoincrement())
  templateId Int
  template   BundleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label      String
  category   String
  minQty     Int            @default(1)
  maxQty     Int            @default(1)
  required   Boolean        @default(true)
  position   Int            @default(0)

  @@index([templateId])
}

model QuantityTier {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQty    Int
  price     Float

  @@index([productId])
