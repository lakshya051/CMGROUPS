# Root .gitignore for Website Project

# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
build/
.next/
out/
.docusaurus/
.cache/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env*
# Allow .env.example/.env.template to be committed as docs.
!.env.example
!.env.template
!**/.env.example
!**/.env.template

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
backend/backend-crash.log
backend/seed-error.log
backend/seed_output.log
backend/prisma_out.txt
frontend/build.log
frontend/build_log*.txt

# Build artifacts / tools that should never be in VCS
bfg.jar

# Local virtualenvs / ad-hoc dirs
.venv-selenium/
once/
# Scratch patches
frontend/temp_patch.js

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE & Editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Project specific
backend/node_modules/
frontend/node_modules/
# Keep backend/prisma/migrations/ in git — required for Render/production `prisma migrate deploy`.
backend/.env
frontend/.env
backend/firebase-service-account*.json
backend/*firebase*.json

# Signing keystores (TWA / Android)
*.jks
*.keystore

# Temporary files
tmp/
temp/

backend/serviceAccountKey.json
backend/src/serviceAccountKey.json
google-credentials.json
backend/cmgroups-sheets-*.json

# Load test artifacts
loadtest/results/
loadtest/node_modules/
